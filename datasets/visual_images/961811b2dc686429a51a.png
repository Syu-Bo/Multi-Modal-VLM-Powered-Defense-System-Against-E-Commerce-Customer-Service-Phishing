<script>
  (function () {
    function loadFonts(useNewFonts) {
      var domain = window.location.origin;
      var os = (
        navigator.userAgentData
          ? navigator.userAgentData.platform
          : navigator.platform || ""
      ).toLowerCase();
      var fontHref = "";
      var isCrossOrigin = false;

      if (useNewFonts) {
        fontHref = domain + "/content/dam/hal/fonts/fonts.css";
      } else {
        if (os.indexOf("mac") !== -1) {
          fontHref = domain + "/mac-fonts.css";
        } else if (os.indexOf("win") !== -1) {
          fontHref = domain + "/win-fonts.css";
        } else {
          fontHref = "https://use.typekit.net/vnd1jbj.css";
          isCrossOrigin = true;
        }
      }

      if (!fontHref) return;

      // Preconnect to Typekit origin to save ~100-200ms on TLS handshake
      if (isCrossOrigin) {
        var preconnect = document.createElement("link");
        preconnect.rel = "preconnect";
        preconnect.href = "https://use.typekit.net";
        preconnect.crossOrigin = "anonymous";
        document.head.appendChild(preconnect);
      }

      // Preload font CSS, swap to stylesheet on load
      var link = document.createElement("link");
      link.rel = "preload";
      link.href = fontHref;
      link.as = "style";
      link.crossOrigin = "anonymous";
      link.onload = function () {
        this.rel = "stylesheet";
      };
      document.head.appendChild(link);

      // Noscript fallback for users with JS disabled
      var ns = document.createElement("noscript");
      var fb = document.createElement("link");
      fb.rel = "stylesheet";
      fb.href = fontHref;
      ns.appendChild(fb);
      document.head.appendChild(ns);

      document.documentElement.setAttribute(
        "data-hal-fonts",
        useNewFonts ? "new" : "original",
      );
    }

    try {
      var cached = sessionStorage.getItem("featureToggleData");
      if (cached) {
        var data = JSON.parse(cached);
        loadFonts(data?.featuredToggle?.is2026FontsEnabled || false);
      } else {
        document.documentElement.setAttribute("data-hal-fonts", "loading");
        window.halFontsNeedLoading = true;
      }
    } catch (e) {
      document.documentElement.setAttribute("data-hal-fonts", "loading");
      window.halFontsNeedLoading = true;
    }

    window.loadHalFonts = loadFonts;
  })();
</script>


  
    
